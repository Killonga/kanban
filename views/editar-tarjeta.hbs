<div class="nueva-tarjeta-form">
  <h3> Editar Tarjeta</h3>

  <form method="POST" action="/editar-tarjeta">

    {{!-- id oculto para saber cual tarjeta modificar --}}
    <input type="hidden" name="id" value="{{tarjeta.id}}">

    <div class="form-grid">

      <div class="form-group span-2">
        <label>Título *</label>
        <input type="text" name="titulo" value="{{tarjeta.titulo}}" required>
      </div>

      <div class="form-group span-2">
        <label>Descripción</label>
        <input type="text" name="descripcion" value="{{tarjeta.descripcion}}">
      </div>

      <div class="form-group">
        <label>Prioridad</label>
        <select name="prioridad">
          <option value="Feature"     {{#if (eq tarjeta.prioridad 'Feature')}}     selected {{/if}}>Feature</option>
          <option value="Task"        {{#if (eq tarjeta.prioridad 'Task')}}        selected {{/if}}>Task</option>
          <option value="Bug"         {{#if (eq tarjeta.prioridad 'Bug')}}         selected {{/if}}>Bug</option>
          <option value="Improvement" {{#if (eq tarjeta.prioridad 'Improvement')}} selected {{/if}}>Improvement</option>
        </select>
      </div>

      <div class="form-group">
        <label>TAG</label>
        <select name="tag">
          <option value="FEATURE" {{#if (eq tarjeta.tag 'FEATURE')}} selected {{/if}}>FEATURE</option>
          <option value="BUG"     {{#if (eq tarjeta.tag 'BUG')}}     selected {{/if}}>BUG</option>
          <option value="HOTFIX"  {{#if (eq tarjeta.tag 'HOTFIX')}}  selected {{/if}}>HOTFIX</option>
        </select>
      </div>

      <div class="form-group">
        <label>Estado</label>
        <select name="estado">
          <option value="Backlog" {{#if (eq tarjeta.estado 'Backlog')}} selected {{/if}}>Backlog</option>
          <option value="Doing"   {{#if (eq tarjeta.estado 'Doing')}}   selected {{/if}}>Doing</option>
          <option value="Review"  {{#if (eq tarjeta.estado 'Review')}}  selected {{/if}}>Review</option>
          <option value="Done"    {{#if (eq tarjeta.estado 'Done')}}    selected {{/if}}>Done</option>
        </select>
      </div>

      <div class="form-group">
        <label>Fecha Inicio</label>
        <input type="date" name="fecha_inicio" value="{{tarjeta.fecha_inicio}}">
      </div>

      <div class="form-group">
        <label>Fecha Fin</label>
        <input type="date" name="fecha_fin" value="{{tarjeta.fecha_fin}}">
      </div>

      <div class="form-group">
        <label>Autor</label>
        <input type="text" name="autor" value="{{tarjeta.autor}}">
      </div>

      <div class="form-group">
        <label>Responsable</label>
        <input type="text" name="responsable" value="{{tarjeta.responsable}}">
      </div>

    </div>

    <div style="display:flex; gap:1rem;">
      <button type="submit" class="btn btn-primary">Guardar cambios</button>
      <a href="/dashboard" class="btn btn-secondary">Cancelar</a>
    </div>

  </form>
</div>